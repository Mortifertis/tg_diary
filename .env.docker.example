APP_ENV=dev
BOT_TOKEN=replace-with-telegram-bot-token
DATABASE_URL=postgresql+psycopg2://tg_diary:tg_diary@db:5432/tg_diary
REDIS_URL=redis://redis:6379/0
REDIS_CONNECT_RETRIES=5
REDIS_RETRY_DELAY_SECONDS=1.0
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_DAILY_TIME=09:00
DEFAULT_WEEKLY_DAY=6
DEFAULT_WEEKLY_TIME=20:00
DEFAULT_MONTHLY_DAY=1
DEFAULT_MONTHLY_TIME=20:00
REMINDER_EVENING_HOUR=20
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_TRACES_SAMPLE_RATE=0.0
OBSERVABILITY_HOST=0.0.0.0
OBSERVABILITY_PORT=8001
RUN_MIGRATIONS_ON_STARTUP=false